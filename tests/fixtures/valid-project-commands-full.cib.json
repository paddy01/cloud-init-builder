{
  "formatVersion": 1,
  "metadata": {
    "name": "Commands Full Template",
    "createdAt": "2026-06-01T10:00:00.000Z",
    "updatedAt": "2026-06-01T12:30:00.000Z",
    "appVersion": "0.1.0"
  },
  "identity": {
    "hostname": "web01",
    "fqdn": "web01.lan.example.com",
    "prefer_fqdn_over_hostname": true,
    "manage_etc_hosts": "localhost",
    "timezone": "Europe/Stockholm",
    "locale": "en_US.UTF-8"
  },
  "users": {
    "preserveDefault": true,
    "entries": [
      {
        "id": "full-1",
        "name": "deploy",
        "gecos": "Deploy User",
        "groups": ["docker"],
        "shell": "/bin/bash",
        "sudo": "ALL=(ALL) NOPASSWD:ALL",
        "primary_group": "deploy",
        "homedir": "/srv/deploy",
        "lock_passwd": true
      }
    ]
  },
  "commands": {
    "bootcmd": [
      {
        "id": "boot-shell",
        "form": "shell",
        "command": "mkdir -p /run/cloud-init-builder"
      },
      {
        "id": "boot-argv",
        "form": "argv",
        "executable": "/bin/true",
        "arguments": []
      }
    ],
    "runcmd": [
      {
        "id": "run-shell",
        "form": "shell",
        "command": "apt-get update"
      },
      {
        "id": "run-argv",
        "form": "argv",
        "executable": "touch",
        "arguments": [{ "id": "arg-1", "value": "/run/foo" }]
      },
      {
        "id": "run-meta",
        "form": "shell",
        "command": "printf \"|\" \"$HOME\""
      }
    ]
  }
}
